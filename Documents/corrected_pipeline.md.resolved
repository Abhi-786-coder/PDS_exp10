## Flaw 4 — SHAP Cross-Validation Against Structural Alerts

### The Error
SHAP surfaces **statistically discriminative** features — not causal ones. If training data is thin for a rare scaffold, SHAP will confidently point at the wrong fragment. The pipeline then surgically modifies the wrong atom.

### The Correction: Alert Overlap Validation

```python
from rdkit.Chem import MolFromSmarts

# Brenk structural alerts (curated from literature)
BRENK_ALERTS = {
    'Michael_Acceptor':     '[CH]=[CH]C(=O)',
    'Epoxide':              'C1OC1',
    'Nitro_Aromatic':       '[NX3](=O)=O',
    'Aniline':              'Nc1ccccc1',
    'Quinone':              'O=C1C=CC(=O)C=C1',
    'Aldehyde':             '[CX3H1](=O)',
    'Halopyrimidine':       'c1nc(Cl)ncn1',
    'Acyl_Halide':          '[CX3](=O)[F,Cl,Br,I]',
    'Azide':                '[NX2-]=[NX2+]=[NX1]',
    'Diazo':                '[CX3]=[NX2+]=[NX1-]',
}

# PAINS filters (Pan-Assay Interference Compounds)
from rdkit.Chem.FilterCatalog import FilterCatalog, FilterCatalogParams

def flag_pains(mol):
    params = FilterCatalogParams()
    params.AddCatalog(FilterCatalogParams.FilterCatalogs.PAINS)
    catalog = FilterCatalog(params)
    entry = catalog.GetFirstMatch(mol)
    return entry.GetDescription() if entry else None

def validate_shap_attribution(smiles: str, 
                               top_shap_bit: int,
                               shap_fragment_atoms: list,
                               radius: int = 2) -> dict:
    """
    Cross-validate SHAP top attribution against known structural alerts.
    
    Returns confidence level of the attribution.
    """
    mol = Chem.MolFromSmiles(smiles)
    
    # Check Brenk alerts
    triggered_alerts = []
    for name, smarts in BRENK_ALERTS.items():
        pattern = MolFromSmarts(smarts)
        if pattern and mol.HasSubstructMatch(pattern):
            match_atoms = set(mol.GetSubstructMatch(pattern))
            shap_atoms = set(shap_fragment_atoms)
            overlap = match_atoms & shap_atoms
            if overlap:
                triggered_alerts.append({
                    'alert': name,
                    'overlap_atoms': list(overlap),
                    'overlap_ratio': len(overlap) / len(match_atoms)
                })
    
    # Check PAINS
    pains_hit = flag_pains(mol)
    
    if len(triggered_alerts) > 0:
        confidence = 'HIGH'  # SHAP agrees with known chemistry
        message = f"✅ SHAP attribution confirmed by: {[a['alert'] for a in triggered_alerts]}"
    elif pains_hit:
        confidence = 'MEDIUM'
        message = f"⚠️ PAINS alert detected ({pains_hit}) but not overlapping SHAP fragment"
    else:
        confidence = 'LOW'
        message = "⚠️ SHAP points at fragment with no known structural alert — attribution may be spurious"
    
    return {
        'shap_confidence': confidence,
        'triggered_alerts': triggered_alerts,
        'pains_hit': pains_hit,
        'message': message,
        'recommendation': 'PROCEED' if confidence in ['HIGH', 'MEDIUM'] else 
                          'DO NOT SUBSTITUTE — attribution unvalidated'
    }
```

