## Complete Corrected Pipeline (All 4 Steps)

```python
def corrected_prescription_pipeline(query_smiles: str,
                                     model,           # Multi-label classifier
                                     training_fps,    # For OOD detection
                                     drugbank_fps,    # For coverage check
                                     temperatures,    # Per-endpoint calibration
                                     bioisostere_db,  # Replacement database
                                     TARGET_COLS) -> dict:
    
    results = {'input': query_smiles, 'candidates': []}
    
    # ── STEP 1: Predict all 12 endpoints ──────────────────────────────────
    fp = smiles_to_morgan(query_smiles)
    original_scores = predict_all_endpoints(model, fp, temperatures)
    
    # ── STEP 1b: SHAP + alert cross-validation ────────────────────────────
    shap_result = compute_shap_top_fragment(model, fp, query_smiles)
    alert_validation = validate_shap_attribution(
        query_smiles, shap_result['top_bit'], shap_result['atom_indices']
    )
    
    if alert_validation['recommendation'] == 'DO NOT SUBSTITUTE':
        return {
            **results,
            'status': 'ATTRIBUTION_UNVALIDATED',
            'message': alert_validation['message'],
            'shap_confidence': 'LOW'
        }
    
    # ── STEP 2: Map bit → fragment ────────────────────────────────────────
    toxic_fragment = shap_result['top_fragment']
    
    # ── STEP 3: Get bioisostere candidates ───────────────────────────────
    coverage = compute_drugbank_similarity(query_smiles, drugbank_fps)
    raw_candidates = bioisostere_db.get(toxic_fragment, [])
    
    viable_candidates, rejected = filter_candidates_by_synthesizability(raw_candidates)
    
    # ── STEP 4: Re-predict all 12 for each viable candidate ───────────────
    for candidate in viable_candidates:
        mod_fp = smiles_to_morgan(candidate['smiles'])
        mod_scores = predict_all_endpoints(model, mod_fp, temperatures)
        
        ood = compute_ood_flag(candidate['smiles'], training_fps)
        pareto_result = evaluate_swap_pareto(original_scores, mod_scores, TARGET_COLS)
        
        # Format with uncertainty
        endpoint_details = {}
        for i, target in enumerate(TARGET_COLS):
            endpoint_details[target] = format_prediction_with_uncertainty(
                mod_scores[i], temperatures[i], ood
            )
        
        results['candidates'].append({
            'smiles': candidate['smiles'],
            'swap': candidate['description'],
            'pareto_status': pareto_result['status'],
            'improved_endpoints': pareto_result['improved_endpoints'],
            'worsened_endpoints': pareto_result['worsened_endpoints'],
            'net_burden_change': pareto_result['net_burden_change'],
            'synthesizability': candidate['synthesizability'],
            'ood_info': ood,
            'endpoint_predictions': endpoint_details,
        })
    
    # Sort: Pareto dominators first, then trade-offs, then no-change
    priority = {'DOMINATES': 0, 'TRADE-OFF': 1, 'NO_CHANGE': 2, 'DOMINATED': 3}
    results['candidates'].sort(key=lambda x: priority.get(x['pareto_status'], 3))
    
    results['coverage_warning'] = coverage['warning']
    results['attribution_confidence'] = alert_validation['shap_confidence']
    results['rejected_candidates'] = rejected  # Transparent about what was filtered
    results['scope_disclaimer'] = SCOPE_DISCLAIMER
    
    return results
```

