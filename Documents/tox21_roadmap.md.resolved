## Phase 4 — ToxNet Training with OPTUNA

### Architecture: Shared Backbone + Per-Endpoint Heads

```python
import torch.nn as nn

class ToxNet(nn.Module):
    def __init__(self, input_dim=2048, shared_dims=[1024,512,256], head_dim=64, n_tasks=12):
        super().__init__()
        layers, prev = [], input_dim
        for h in shared_dims:
            layers += [nn.Linear(prev,h), nn.BatchNorm1d(h), nn.GELU(), nn.Dropout(0.3)]
            prev = h
        self.backbone = nn.Sequential(*layers)
        
        # 12 independent heads — one per Tox21 endpoint
        self.heads = nn.ModuleList([
            nn.Sequential(nn.Linear(prev,head_dim), nn.ReLU(), nn.Dropout(0.15), nn.Linear(head_dim,1))
            for _ in range(n_tasks)
        ])
    
    def forward(self, x):
        shared = self.backbone(x)
        return torch.cat([h(shared) for h in self.heads], dim=1)
    
    def get_embeddings(self, x):
        return self.backbone(x)
```

### OPTUNA Hyperparameter Search (Corrected for Neural Networks)

> [!CAUTION]
> The previous version of this roadmap suggested tuning `n_estimators`, `max_depth`, and `colsample_bytree`. Those are tree-based hyperparameters (XGBoost/Random Forest). We are training **ToxNet**, which is a PyTorch Neural Network. Attempting to pass tree parameters to PyTorch is a fatal ML architecture error. Tune neural parameters instead.

```python
import optuna

def objective(trial):
    params = {
        'learning_rate': trial.suggest_float('lr', 1e-4, 1e-2, log=True),
        'dropout':       trial.suggest_float('dropout', 0.1, 0.5),
        'batch_size':    trial.suggest_categorical('batch_size', [32, 64, 128]),
        'focal_gamma':   trial.suggest_float('gamma', 1.0, 5.0),
        'shared_dims':   trial.suggest_categorical('dims', [
                             [1024, 512, 256], 
                             [512, 256, 128]
                         ]),
        'weight_decay':  trial.suggest_float('weight_decay', 1e-6, 1e-3, log=True)
    }
    
    # Train ToxNet with these params and evaluate on macro AUPRC
    score = cross_val_auprc_toxnet(params, X_train, Y_train)
    return score  # Maximize AUPRC

# ─── Early Stopping: Let Convergence Determine Trial Count ───────────────────
# We do NOT hardcode 50 trials. The callback stops when AUPRC stagnates.
from optuna.callbacks import EarlyStoppingCallback

study = optuna.create_study(direction='maximize')
study.optimize(
    objective,
    n_trials=200,                                    # Maximum ceiling (safety limit)
    callbacks=[EarlyStoppingCallback(10, direction='maximize')]  # Stop if no improvement for 10 trials
)
print(f"✅ Converged at trial {len(study.trials)} / 200")
print(f"   Best Macro AUPRC: {study.best_value:.4f}")
print(f"   Best params: {study.best_params}")
# Plot convergence to prove the optimization did not terminate prematurely:
# optuna.visualization.plot_optimization_history(study)
```

