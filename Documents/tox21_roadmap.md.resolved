### SMILES Validation Gate — Run First, Always

> [!WARNING]
> Every downstream function assumes valid SMILES. `Chem.MolFromSmiles()` returns `None` silently for invalid inputs, which propagates as `IndexError` or `NaN` loss hours into training. Run this once at ingestion and index everything downstream off the validated list.

```python
from rdkit import Chem
from rdkit.Chem.SaltRemover import SaltRemover
from rdkit.Chem.MolStandardize import rdMolStandardize
import pandas as pd

# ─── Fix #1: Salt Remover & Tautomer Standardizer ───────────────────────────
_remover    = SaltRemover()                       # strips counterions (.HCl, .Na, etc.)
_normalizer = rdMolStandardize.Normalizer()       # normalizes functional groups

def preprocess_smiles(smiles: str):
    """Validate → Strip salts → Normalize. Returns canonical SMILES or None."""
    mol = Chem.MolFromSmiles(smiles)
    if mol is None:
        return None
    mol = _remover.StripMol(mol, dontRemoveEverything=True)  # Remove counterions
    mol = _normalizer.normalize(mol)                          # Normalize groups
    return Chem.MolToSmiles(mol)   # Return canonical SMILES

# ─── Fix #2: Load + Validate + Deduplicate ───────────────────────────────────
df = pd.read_csv('tox21.csv')

# Step A: Preprocess SMILES
df['canonical_smiles'] = df['smiles'].apply(preprocess_smiles)
before = len(df)
df = df.dropna(subset=['canonical_smiles'])       # Drop invalid SMILES
print(f"✅ Dropped {before - len(df)} invalid/empty SMILES")

# Step B: Deduplicate (same canonical SMILES = same molecule)
# For conflicting labels on duplicates, keep the TOXIC label (conservative)
TARGET_COLS = [c for c in df.columns if c not in ['smiles', 'canonical_smiles', 'mol_id']]
df = df.sort_values(TARGET_COLS, ascending=False)  # Toxic (1) rows float to top
df = df.drop_duplicates(subset='canonical_smiles', keep='first').reset_index(drop=True)
print(f"✅ {len(df)} unique compounds after deduplication")
```

