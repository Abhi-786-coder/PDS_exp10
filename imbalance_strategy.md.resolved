# ⚖️ Imbalanced Data Strategy — Full Stack
## Tox21 Multi-Label Toxicity Pipeline

---

> [!IMPORTANT]
> The most important insight is at the end of this document (Section 6). Everything else is well-known. The **geometric imbalance problem** — the imbalance underneath the imbalance — is what separates a research contribution from a textbook exercise.

---

## The Five Layers of the Problem

```
Layer 5: Architecture    ← Per-endpoint heads + shared backbone
Layer 4: Threshold       ← Recall floor ≥ 0.85 per endpoint
Layer 3: Evaluation      ← AUPRC primary (not AUROC, never accuracy)
Layer 2: Loss Function   ← Focal Loss + per-endpoint weights  ← Biggest gain
Layer 1: Data            ← SMOTE in embedding space + Tomek Links
                                     ↑
                           NOT on raw fingerprints
```

---

## Layer 1 — Data Level

### What NOT to Do (and Why)

```python
# ❌ WRONG — SMOTE directly on Morgan fingerprints
from imblearn.over_sampling import SMOTE
smote = SMOTE()
X_resampled, y_resampled = smote.fit_resample(X_fingerprints, y_train)

# Why this is wrong:
# Morgan fingerprints are BINARY bit vectors in a 2048-dimensional space.
# Interpolating two valid fingerprints: [1,0,1,0,...] + [0,1,0,1,...] = [0.5, 0.5, 0.5...]
# This is NOT a valid fingerprint and does NOT correspond to any real molecule.
# You are generating physically meaningless feature vectors.
```

### What To Do Instead

#### Option A — SMOTE in Learned Embedding Space (Correct)
```python
import torch
import torch.nn as nn
from imblearn.over_sampling import SMOTE, ADASYN
from imblearn.under_sampling import TomekLinks

class MolecularEncoder(nn.Module):
    """
    First, learn a 128-dimensional embedding of the molecule.
    SMOTE operates in this continuous embedding space — not in binary fingerprint space.
    """
    def __init__(self, input_dim=2048, embed_dim=128):
        super().__init__()
        self.encoder = nn.Sequential(
            nn.Linear(input_dim, 512),
            nn.BatchNorm1d(512),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(512, 256),
            nn.ReLU(),
            nn.Linear(256, embed_dim)
        )
    
    def forward(self, x):
        return self.encoder(x)

# Step 1: Train the encoder (as part of multi-task model)
# Step 2: Extract embeddings
encoder = MolecularEncoder()
# ... train encoder ...
with torch.no_grad():
    embeddings = encoder(torch.tensor(X_fingerprints, dtype=torch.float32)).numpy()
    # Shape: (N, 128) — continuous, SMOTE-safe

# Step 3: SMOTE on continuous embeddings (per target)
def resample_endpoint(embeddings, y_endpoint, strategy='adasyn'):
    mask = y_endpoint != -1  # Only use known labels
    X_known = embeddings[mask]
    y_known = y_endpoint[mask]
    
    if strategy == 'adasyn':
        resampler = ADASYN(random_state=42, n_neighbors=5)
    else:
        resampler = SMOTE(random_state=42, k_neighbors=5)
    
    X_res, y_res = resampler.fit_resample(X_known, y_known)
    
    # Clean decision boundary
    tomek = TomekLinks()
    X_clean, y_clean = tomek.fit_resample(X_res, y_res)
    
    return X_clean, y_clean
```

#### Option B — Class Weights (No Data Modification, Often Sufficient)
```python
import numpy as np

def compute_per_endpoint_weights(Y_train: np.ndarray, TARGET_COLS: list) -> dict:
    """
    Compute pos_weight for each of the 12 endpoints.
    pos_weight = neg_count / pos_count (per endpoint)
    """
    weights = {}
    for i, target in enumerate(TARGET_COLS):
        y = Y_train[:, i]
        mask = y != -1  # Exclude unknowns
        y_known = y[mask]
        
        neg_count = (y_known == 0).sum()
        pos_count = (y_known == 1).sum()
        
        # Guard against zero
        weight = neg_count / max(pos_count, 1)
        weights[target] = round(weight, 2)
    
    return weights

# Result on Tox21 training set:
# endpoint_weights = {
#     'NR-AR':        18.2,   # 5.2% toxic
#     'NR-AR-LBD':    34.7,   # 2.8% toxic ← most severe
#     'NR-AhR':        5.4,
#     'NR-Aromatase':  9.1,
#     'NR-ER':         7.3,
#     'NR-ER-LBD':    11.8,
#     'NR-PPAR-gamma': 6.2,
#     'SR-ARE':        4.8,
#     'SR-ATAD5':     12.1,
#     'SR-HSE':        7.5,
#     'SR-MMP':        5.9,
#     'SR-p53':        8.1,
# }
```

---

## Layer 2 — Loss Function (Biggest Gain)

### Why Focal Loss Outperforms Weighted BCE

```
Standard Weighted BCE:
  - Weights every toxic sample equally
  - Easy toxic examples (clearly toxic) get same weight as hard toxic examples
  - Model wastes capacity on examples it already correctly classifies

Focal Loss:
  - Down-weights easy examples (confident predictions, near 0 or 1)
  - Up-weights hard examples (uncertain predictions, near 0.5)
  - Model is FORCED to focus on the ambiguous, hard-to-classify frontier
  - This is where all the real learning happens in imbalanced data
```

### Focal Loss — Full Implementation

```python
import torch
import torch.nn.functional as F

class FocalLoss(nn.Module):
    """
    Focal Loss: FL(p) = -α(1-p)^γ log(p)
    
    γ (gamma): Focus parameter
        γ=0 → standard BCE
        γ=2 → standard focal loss (recommended starting point)
        γ=5 → very aggressive focus on hard examples
    
    α (alpha): Class balance parameter (equivalent to pos_weight)
    """
    def __init__(self, gamma: float = 2.0, alpha: float = None, reduction: str = 'mean'):
        super().__init__()
        self.gamma = gamma
        self.alpha = alpha
        self.reduction = reduction
    
    def forward(self, logits: torch.Tensor, targets: torch.Tensor, 
                mask: torch.Tensor = None) -> torch.Tensor:
        
        # Numerically stable sigmoid BCE
        bce_loss = F.binary_cross_entropy_with_logits(
            logits, targets, reduction='none'
        )
        
        # p_t is the model's probability for the true class
        probs = torch.sigmoid(logits)
        p_t = probs * targets + (1 - probs) * (1 - targets)
        
        # Focal weight: down-weights easy examples
        focal_weight = (1 - p_t) ** self.gamma
        
        # Alpha weighting for class balance
        if self.alpha is not None:
            alpha_t = self.alpha * targets + (1 - self.alpha) * (1 - targets)
            focal_weight = alpha_t * focal_weight
        
        focal_loss = focal_weight * bce_loss
        
        # Apply NaN mask (unknown Tox21 labels)
        if mask is not None:
            focal_loss = focal_loss * mask
            return focal_loss.sum() / mask.sum().clamp(min=1)
        
        if self.reduction == 'mean':
            return focal_loss.mean()
        return focal_loss.sum()


class PerEndpointFocalLoss(nn.Module):
    """
    Applies Focal Loss with per-endpoint alpha weights.
    Each of the 12 Tox21 targets has its own imbalance ratio.
    """
    def __init__(self, pos_weights: dict, target_names: list, gamma: float = 2.0):
        super().__init__()
        self.gamma = gamma
        # Normalize weights to [0, 1] as alpha for focal loss
        raw = torch.tensor([pos_weights[t] for t in target_names])
        self.alpha = (raw / (raw + 1)).unsqueeze(0)  # Shape: (1, 12)
        self.target_names = target_names
    
    def forward(self, logits: torch.Tensor, targets: torch.Tensor) -> torch.Tensor:
        """
        logits:  (batch, 12)
        targets: (batch, 12)  — -1 for unknown labels
        """
        mask = (targets != -1).float()
        targets_clean = targets.clone().float()
        targets_clean[targets == -1] = 0.0  # Dummy value, masked out
        
        alpha = self.alpha.to(logits.device).expand_as(logits)
        
        probs = torch.sigmoid(logits)
        p_t = probs * targets_clean + (1 - probs) * (1 - targets_clean)
        alpha_t = alpha * targets_clean + (1 - alpha) * (1 - targets_clean)
        
        bce = F.binary_cross_entropy_with_logits(logits, targets_clean, reduction='none')
        focal = alpha_t * (1 - p_t) ** self.gamma * bce
        
        # Mask out unknowns
        masked = focal * mask
        return masked.sum() / mask.sum().clamp(min=1)
```

### Gamma Hyperparameter Guide

| γ value | Behavior | Use When |
|---------|----------|----------|
| 0 | Standard weighted BCE | Baseline |
| 1 | Mild focus | Light imbalance (10:1) |
| **2** | **Standard focal (recommended)** | **Most Tox21 endpoints** |
| 3–4 | Aggressive focus | NR-AR-LBD (34:1 imbalance) |
| 5+ | Very aggressive | Rarely useful, prone to instability |

---

## Layer 3 — Evaluation (Where Most Projects Fail Silently)

### The Metric Hierarchy (Never Report Accuracy)

```
PRIMARY:   AUPRC (Average Precision)
           ↑ Focuses exclusively on minority class
           ↑ A random classifier gets AUPRC = prevalence (e.g., 0.05)
           ↑ Directly reflects what you care about: finding toxic compounds

SECONDARY: AUROC
           ↑ Threshold-independent ranking quality
           ↑ A random classifier always gets 0.5
           ↓ Can look good even when minority class is mostly wrong

SECONDARY: F1 @ Optimal Threshold
           ↑ Single-number summary at deployment threshold
           ↓ Depends on threshold choice

SECONDARY: MCC (Matthews Correlation Coefficient)
           ↑ Accounts for all 4 cells of confusion matrix
           ↑ Robust to imbalance
           ↑ Range: [-1, +1], 0 = random

NEVER:     Accuracy — meaningless under imbalance
```

### Full Evaluation Suite (Per Endpoint)

```python
from sklearn.metrics import (
    roc_auc_score, 
    average_precision_score,
    precision_recall_curve,
    matthews_corrcoef,
    f1_score
)
import pandas as pd

def evaluate_all_endpoints(Y_true: np.ndarray, 
                            Y_proba: np.ndarray,
                            Y_pred: np.ndarray,
                            TARGET_COLS: list) -> pd.DataFrame:
    """
    Comprehensive per-endpoint evaluation.
    Y_true: (N, 12) — -1 for unknown
    Y_proba: (N, 12) — probability scores
    Y_pred: (N, 12) — binary predictions at optimal threshold
    """
    results = []
    
    for i, target in enumerate(TARGET_COLS):
        mask = Y_true[:, i] != -1
        y_true = Y_true[mask, i]
        y_prob = Y_proba[mask, i]
        y_pred = Y_pred[mask, i]
        
        prevalence = y_true.mean()
        
        auroc = roc_auc_score(y_true, y_prob)
        auprc = average_precision_score(y_true, y_prob)
        auprc_lift = auprc / prevalence  # vs random baseline
        mcc = matthews_corrcoef(y_true, y_pred)
        f1 = f1_score(y_true, y_pred, zero_division=0)
        
        toxic_count = y_true.sum()
        total = len(y_true)
        
        results.append({
            'Endpoint': target,
            'Prevalence': f"{prevalence:.1%}",
            'Toxic/Total': f"{int(toxic_count)}/{total}",
            'AUPRC': round(auprc, 4),         # ← PRIMARY METRIC
            'AUPRC Lift': f"{auprc_lift:.1f}x",# vs random
            'AUROC': round(auroc, 4),
            'F1': round(f1, 4),
            'MCC': round(mcc, 4),
        })
    
    df = pd.DataFrame(results)
    
    # Macro averages
    macro_row = {
        'Endpoint': '── MACRO AVG ──',
        'AUPRC': round(df['AUPRC'].mean(), 4),
        'AUROC': round(df['AUROC'].mean(), 4),
        'F1': round(df['F1'].mean(), 4),
        'MCC': round(df['MCC'].mean(), 4),
    }
    df = pd.concat([df, pd.DataFrame([macro_row])], ignore_index=True)
    
    return df

# Expected output format:
# Endpoint        Prevalence  Toxic/Total  AUPRC   AUPRC Lift  AUROC   F1     MCC
# NR-AR           5.2%        299/5756     0.412   7.9x        0.832   0.411  0.397
# NR-AR-LBD       2.8%        161/5748     0.276   9.9x        0.819   0.321  0.312
# ...
# ── MACRO AVG ──                          0.381               0.821   0.389  0.374
```

